{
  "name": "agy-acp",
  "version": "0.3.0",
  "description": "Agent Client Protocol adapter that wraps the Google Antigravity CLI (ACP v1 + experimental draft ACP v2)",
  "type": "module",
  "author": {
    "name": "shidngew"
  },
  "homepage": "https://github.com/shindgew/agy-acp#readme",
  "bugs": {
    "url": "https://github.com/shindgew/agy-acp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shindgew/agy-acp.git"
  },
  "keywords": [
    "acp",
    "agent",
    "antigravity",
    "google"
  ],
  "main": "dist/agent.js",
  "types": "dist/agent.d.ts",
  "license": "Apache-2.0",
  "bin": {
    "agy-acp": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "npm run typecheck && vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.3.0",
    "@bufbuild/protobuf": "^2.13.0",
    "better-sqlite3": "^13.0.1",
    "node-pty": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "allowScripts": {
    "node-pty@1.1.0": true,
    "better-sqlite3@13.0.1": true
  }
}
